module probe;

import std.core as core;

export {
	ProbeError,
	make_probe_ok,
	make_probe_err,
	make_string_err
};

pub error ProbeError {
	code: Int,
}

pub fn make_probe_ok() nothrow -> core.Result<Int, ProbeError> {
	return core.Result::Ok(42);
}

pub fn make_probe_err() nothrow -> core.Result<Int, ProbeError> {
	return core.Result::Err(ProbeError(code = 42));
}

pub fn make_string_err() nothrow -> core.Result<Int, String> {
	return core.Result::Err("bad");
}
