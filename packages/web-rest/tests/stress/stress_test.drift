module web.rest.tests.stress.stress_test

import std.core as core;
import std.io as io;
import std.net as net;
import std.concurrent as conc;
import std.time as time;
import std.parse as parse;
import web.jwt as jwt;
import web.rest as rest;
import web.rest.app as rest_app;

// Stress & correctness tests for the REST server.
// Separated from unit tests: slower, timing-sensitive, exercises sustained load.

// --- Shared byte/string helpers ---

fn _to_bytes(s: &String) nothrow -> Array<Byte> {
	var out: Array<Byte> = [];
	var i = 0;
	val n = s.byte_length();
	while i < n {
		out.push(core.string_byte_at(s, i));
		i = i + 1;
	}
	return move out;
}

fn _bytes_to_string(raw: &Array<Byte>) nothrow -> String {
	val n = raw.len;
	if n == 0 {
		return "";
	}
	var b = io.buffer(n);
	var i = 0;
	while i < n {
		io.buffer_write(&mut b, i, raw[i]);
		i = i + 1;
	}
	return core.string_from_utf8_bytes(io.buffer_ptr(&b), n);
}

// --- Shared string matchers ---

fn _contains(haystack: &String, needle: &String) nothrow -> Bool {
	val h_len = haystack.byte_length();
	val n_len = needle.byte_length();
	if n_len > h_len {
		return false;
	}
	var i = 0;
	val limit = h_len - n_len + 1;
	while i < limit {
		var matched = true;
		var j = 0;
		while j < n_len {
			if core.string_byte_at(haystack, i + j) != core.string_byte_at(needle, j) {
				matched = false;
				j = n_len;
			} else {
				j = j + 1;
			}
		}
		if matched {
			return true;
		}
		i = i + 1;
	}
	return false;
}

fn _starts_with(s: &String, prefix: &String) nothrow -> Bool {
	val p_len = prefix.byte_length();
	if s.byte_length() < p_len {
		return false;
	}
	var i = 0;
	while i < p_len {
		if core.string_byte_at(s, i) != core.string_byte_at(prefix, i) {
			return false;
		}
		i = i + 1;
	}
	return true;
}

// --- Shared TCP helpers ---

fn _http_roundtrip(port: Int, raw_request: &String, timeout: conc.Duration) nothrow -> core.Result<String, Int> {
	var addr = net.socket_addr("127.0.0.1", port);
	match net.connect(&addr, timeout) {
		core.Result::Err(_) => { return core.Result::Err(1); },
		core.Result::Ok(conn) => {
			var stream = move conn;
			val req_bytes = _to_bytes(raw_request);
			var wbuf = io.buffer(req_bytes.len);
			var i = 0;
			while i < req_bytes.len {
				io.buffer_write(&mut wbuf, i, req_bytes[i]);
				i = i + 1;
			}
			match stream.write(&wbuf, timeout) {
				core.Result::Err(_) => {
					val _ = stream.close(timeout);
					return core.Result::Err(2);
				},
				core.Result::Ok(_) => {}
			}
			var collected: Array<Byte> = [];
			var done = false;
			while !done {
				var rbuf = io.buffer(4096);
				match stream.read(&mut rbuf, timeout) {
					core.Result::Err(_) => { done = true; },
					core.Result::Ok(n) => {
						if n == 0 {
							done = true;
						} else {
							var j = 0;
							while j < n {
								collected.push(io.buffer_read(&mut rbuf, j));
								j = j + 1;
							}
						}
					}
				}
			}
			val _ = stream.close(timeout);
			return core.Result::Ok(_bytes_to_string(&collected));
		}
	}
}

fn _run_serve(a: rest.App, listener: net.TcpListener, handle: rest.ServerHandle, timeout: conc.Duration) nothrow -> Int {
	match rest.serve(move a, move listener, move handle, timeout) {
		core.Result::Ok(_) => { return 0; },
		core.Result::Err(_) => { return 1; }
	}
}

// --- Multi-roundtrip lifecycle helper ---
//
// Sets up server with max_requests = requests.len, sends all requests
// sequentially, collects responses. Stops server and joins VT before
// returning.

fn _multi_roundtrip(app: rest.App, requests: &Array<String>, timeout: conc.Duration) nothrow -> core.Result<Array<String>, Int> {
	match rest.listen_app(&app, timeout) {
		core.Result::Err(_) => { return core.Result::Err(1); },
		core.Result::Ok(lst) => {
			var listener = move lst;
			val port = listener.local_port();
			var handle = rest.new_server_handle();
			handle.max_requests = requests.len;
			var caller_handle = rest.clone_handle(&handle);
			var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy timeout) => {
				return _run_serve(move app, move listener, move handle, timeout);
			});

			var responses: Array<String> = [];
			var ok = true;
			var i = 0;
			while i < requests.len {
				if ok {
					match _http_roundtrip(port, &requests[i], timeout) {
						core.Result::Err(_) => {
							ok = false;
						},
						core.Result::Ok(resp_str) => {
							responses.push(move resp_str);
						}
					}
				}
				i = i + 1;
			}

			rest.stop(&caller_handle);
			match sv.join() {
				core.Result::Err(_) => { return core.Result::Err(2); },
				core.Result::Ok(exit_code) => {
					if exit_code != 0 { return core.Result::Err(3); }
				}
			}

			if !ok {
				return core.Result::Err(4);
			}

			return core.Result::Ok(move responses);
		}
	}
}

// --- JWT helpers ---

fn _test_secret() nothrow -> Array<Byte> {
	var out: Array<Byte> = [cast<Byte>(115), cast<Byte>(101), cast<Byte>(99), cast<Byte>(114), cast<Byte>(101), cast<Byte>(116)];
	return move out;
}

fn _build_policy() nothrow -> jwt.JwtVerifyPolicy {
	var pb = jwt.new_verify_policy_builder();
	pb.require_typ_jwt = false;
	match jwt.build_verify_policy(move pb) {
		core.Result::Ok(v) => { return v; },
		core.Result::Err(_) => {
			return jwt.JwtVerifyPolicy(skew_sec = 0, max_future_iat_sec = 0, require_typ_jwt = false);
		}
	}
}

fn _jwt_guard_owned(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<Void, rest.RestError> {
	var config = rest.new_jwt_guard_config(_test_secret(), _build_policy());
	config.now_unix = time.utc_unix_seconds_now();
	return rest.jwt_guard_apply(&config, req, c);
}

// --- Handler helpers ---

fn _health_handler(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	return core.Result::Ok(rest.json_response(200, "{\"ok\":true}"));
}

fn _echo_query_handler(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	val name = "key";
	match rest.query_param(req, &name) {
		Optional::Some(v) => {
			val body = "{\"key\":\"" + v + "\"}";
			return core.Result::Ok(rest.json_response(200, body));
		},
		Optional::None => {
			return core.Result::Ok(rest.json_response(200, "{\"key\":null}"));
		}
	}
}

fn _echo_body_handler(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	match rest.body_json(req) {
		core.Result::Ok(_) => {
			return core.Result::Ok(rest.json_response(200, "{\"echo\":true}"));
		},
		core.Result::Err(e) => {
			return core.Result::Err(e);
		}
	}
}

fn _me_handler(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	match rest.get_principal(c) {
		Optional::Some(p) => {
			val body = "{\"sub\":\"" + p.sub + "\"}";
			return core.Result::Ok(rest.json_response(200, body));
		},
		Optional::None => {
			return core.Result::Err(rest.rest_error(401, "unauthorized", "missing-principal", "no principal"));
		}
	}
}

// --- Shared client VT helper ---

fn _client_health_check(port: Int, timeout: conc.Duration) nothrow -> Int {
	val raw_req = "GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
	match _http_roundtrip(port, &raw_req, timeout) {
		core.Result::Err(_) => { return 1; },
		core.Result::Ok(resp_str) => {
			val s_200 = "HTTP/1.1 200 OK";
			if !_starts_with(&resp_str, &s_200) { return 2; }
			val m_health = "{\"ok\":true}";
			if !_contains(&resp_str, &m_health) { return 3; }
			return 0;
		}
	}
}

// --- Scenario 1: Many sequential requests, mixed types (100-range) ---
//
// Sends 50 requests cycling through 5 types: health, echo query, echo body,
// 404, and 401. Exercises success paths, error paths, body parsing, query
// params, and guard rejection across a sustained run.

fn scenario_many_sequential_mixed() nothrow -> Int {
	val timeout = conc.Duration(millis = 5000);

	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 101; },
		core.Result::Ok(a) => {
			var app = move a;

			// Ungrouped routes
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 102; },
				core.Result::Ok(_) => {}
			}
			match rest_app.add_route(&mut app, "GET", "/v1/echo", core.callback2(_echo_query_handler)) {
				core.Result::Err(_) => { return 103; },
				core.Result::Ok(_) => {}
			}
			match rest_app.add_route(&mut app, "POST", "/v1/echo", core.callback2(_echo_body_handler)) {
				core.Result::Err(_) => { return 104; },
				core.Result::Ok(_) => {}
			}

			// Guarded group for /v1/me
			match rest.add_group(&mut app, "/v1") {
				core.Result::Err(_) => { return 105; },
				core.Result::Ok(group) => {
					rest.add_group_guard(&mut app, &group, core.callback2(_jwt_guard_owned));
					match rest_app.add_group_route(&mut app, &group, "GET", "/me", core.callback2(_me_handler)) {
						core.Result::Err(_) => { return 106; },
						core.Result::Ok(_) => {}
					}
				}
			}

			// Build 50 requests: 10 cycles of 5 types
			var requests: Array<String> = [];
			var cycle = 0;
			while cycle < 10 {
				var r0 = "GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
				requests.push(move r0);
				var r1 = "GET /v1/echo?key=stress HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
				requests.push(move r1);
				var r2 = "POST /v1/echo HTTP/1.1\r\nHost: localhost\r\nContent-Length: 15\r\nConnection: close\r\n\r\n{\"test\":\"body\"}";
				requests.push(move r2);
				var r3 = "GET /nonexistent HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
				requests.push(move r3);
				var r4 = "GET /v1/me HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
				requests.push(move r4);
				cycle = cycle + 1;
			}

			match _multi_roundtrip(move app, &requests, timeout) {
				core.Result::Err(_) => { return 110; },
				core.Result::Ok(responses) => {
					if responses.len != 50 { return 111; }

					val s_200 = "HTTP/1.1 200 OK";
					val s_404 = "HTTP/1.1 404 Not Found";
					val s_401 = "HTTP/1.1 401 Unauthorized";
					val m_health = "{\"ok\":true}";
					val m_key = "\"key\":\"stress\"";
					val m_echo = "\"echo\":true";
					val m_notfound = "\"event\":\"not-found\"";
					val m_unauth = "\"event\":\"unauthorized\"";

					var j = 0;
					var kind = 0;
					while j < 50 {
						if kind == 0 {
							if !_starts_with(&responses[j], &s_200) { return 120; }
							if !_contains(&responses[j], &m_health) { return 121; }
						}
						if kind == 1 {
							if !_starts_with(&responses[j], &s_200) { return 122; }
							if !_contains(&responses[j], &m_key) { return 123; }
						}
						if kind == 2 {
							if !_starts_with(&responses[j], &s_200) { return 124; }
							if !_contains(&responses[j], &m_echo) { return 125; }
						}
						if kind == 3 {
							if !_starts_with(&responses[j], &s_404) { return 126; }
							if !_contains(&responses[j], &m_notfound) { return 127; }
						}
						if kind == 4 {
							if !_starts_with(&responses[j], &s_401) { return 128; }
							if !_contains(&responses[j], &m_unauth) { return 129; }
						}
						kind = kind + 1;
						if kind >= 5 {
							kind = 0;
						}
						j = j + 1;
					}

					return 0;
				}
			}
		}
	}
}

// --- Scenario 2: Concurrent client connections (200-range) ---
//
// Spawns 10 client VTs that connect ~simultaneously. Server processes them
// one at a time from the accept loop while client VTs park on their own I/O.
// Exercises VT scheduler under contention and OS backlog draining.

fn scenario_concurrent_clients() nothrow -> Int {
	val timeout = conc.Duration(millis = 10000);

	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 201; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 202; },
				core.Result::Ok(_) => {}
			}

			match rest.listen_app(&app, timeout) {
				core.Result::Err(_) => { return 203; },
				core.Result::Ok(lst) => {
					var listener = move lst;
					val port = listener.local_port();
					var handle = rest.new_server_handle();
					handle.max_requests = 10;
					var caller_handle = rest.clone_handle(&handle);

					var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy timeout) => {
						return _run_serve(move app, move listener, move handle, timeout);
					});

					// Spawn 10 client VTs
					var c0 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c1 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c2 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c3 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c4 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c5 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c6 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c7 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c8 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });
					var c9 = conc.spawn_cb(| | captures(copy port, copy timeout) => { return _client_health_check(port, timeout); });

					// Join all 10 — join every VT even if some fail
					var join_err = 0;
					var check_err = 0;

					match c0.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c1.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c2.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c3.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c4.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c5.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c6.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c7.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c8.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }
					match c9.join() { core.Result::Err(_) => { join_err = join_err + 1; }, core.Result::Ok(code) => { if code != 0 { check_err = check_err + 1; } } }

					// Stop server and join
					rest.stop(&caller_handle);
					match sv.join() {
						core.Result::Err(_) => { return 204; },
						core.Result::Ok(exit_code) => {
							if exit_code != 0 { return 205; }
						}
					}

					if join_err > 0 { return 210; }
					if check_err > 0 { return 211; }
					return 0;
				}
			}
		}
	}
}

// --- Scenario 3: Repeated start/stop cycles (300-range) ---
//
// 5 full lifecycles: build app → listen → spawn serve → roundtrip → stop → join.
// Each cycle is a fresh server instance on port 0. Catches leaked fds,
// listener handles, or Arc refcounts across lifecycles. Memcheck pins
// leaked allocations.

fn _start_stop_cycle(timeout: conc.Duration) nothrow -> Int {
	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 1; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 2; },
				core.Result::Ok(_) => {}
			}
			match rest.listen_app(&app, timeout) {
				core.Result::Err(_) => { return 3; },
				core.Result::Ok(lst) => {
					var listener = move lst;
					val port = listener.local_port();
					var handle = rest.new_server_handle();
					handle.max_requests = 1;
					var caller_handle = rest.clone_handle(&handle);
					var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy timeout) => {
						return _run_serve(move app, move listener, move handle, timeout);
					});

					val result = _client_health_check(port, timeout);

					rest.stop(&caller_handle);
					match sv.join() {
						core.Result::Err(_) => { return 4; },
						core.Result::Ok(exit_code) => {
							if exit_code != 0 { return 5; }
						}
					}

					if result != 0 { return 6; }
					return 0;
				}
			}
		}
	}
}

fn scenario_start_stop_cycles() nothrow -> Int {
	val timeout = conc.Duration(millis = 5000);
	var i = 0;
	while i < 5 {
		val result = _start_stop_cycle(timeout);
		if result != 0 { return 300 + result; }
		i = i + 1;
	}
	return 0;
}

// --- Scenario 4: Large headers near limit (400-range) ---
//
// Two sub-cases: safely under 8192-byte MAX_HEADER_SIZE (200 OK) and
// safely over (400 header-too-large). No exact-boundary pinning.

// Build a GET /health request padded to approximately
// 41 + pad_count * 109 bytes (request line + host + N pad headers + terminator).
fn _padded_request(pad_count: Int) nothrow -> String {
	// 100-byte pad value via doubling
	var pad = "AAAAAAAAAA"; // 10
	pad = pad + pad; // 20
	pad = pad + pad; // 40
	pad = pad + pad; // 80
	pad = pad + "AAAAAAAAAAAAAAAAAAAA"; // 100

	var req = "GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n"; // 57 bytes
	var i = 0;
	while i < pad_count {
		req = req + "X-Pad: " + pad + "\r\n"; // 109 bytes each
		i = i + 1;
	}
	req = req + "\r\n"; // 2 bytes
	return req;
}

fn scenario_large_headers() nothrow -> Int {
	val timeout = conc.Duration(millis = 5000);

	// Sub 1: safely under limit — 63 pad headers → ~6908 bytes total → 200 OK
	var b1 = rest.new_app_builder();
	rest.bind(&mut b1, "127.0.0.1", 0);
	match rest.build_app(move b1) {
		core.Result::Err(_) => { return 401; },
		core.Result::Ok(a1) => {
			var app1 = move a1;
			match rest_app.add_route(&mut app1, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 402; },
				core.Result::Ok(_) => {}
			}
			var reqs1: Array<String> = [];
			var r1 = _padded_request(63);
			reqs1.push(move r1);
			match _multi_roundtrip(move app1, &reqs1, timeout) {
				core.Result::Err(_) => { return 403; },
				core.Result::Ok(resps1) => {
					val s_200 = "HTTP/1.1 200 OK";
					if !_starts_with(&resps1[0], &s_200) { return 404; }
					val m_health = "{\"ok\":true}";
					if !_contains(&resps1[0], &m_health) { return 405; }
				}
			}
		}
	}

	// Sub 2: safely over limit — 92 pad headers → ~10069 bytes total → 400
	var b2 = rest.new_app_builder();
	rest.bind(&mut b2, "127.0.0.1", 0);
	match rest.build_app(move b2) {
		core.Result::Err(_) => { return 410; },
		core.Result::Ok(a2) => {
			var app2 = move a2;
			match rest_app.add_route(&mut app2, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 411; },
				core.Result::Ok(_) => {}
			}
			var reqs2: Array<String> = [];
			var r2 = _padded_request(92);
			reqs2.push(move r2);
			match _multi_roundtrip(move app2, &reqs2, timeout) {
				core.Result::Err(_) => { return 412; },
				core.Result::Ok(resps2) => {
					val s_400 = "HTTP/1.1 400 Bad Request";
					if !_starts_with(&resps2[0], &s_400) { return 413; }
					val m_tag = "header-too-large";
					if !_contains(&resps2[0], &m_tag) { return 414; }
				}
			}
		}
	}

	return 0;
}

// --- Scenario 5: Malformed request matrix (500-range) ---
//
// All 7 malformed payloads are sent sequentially to a single server instance
// with max_requests = 7. This proves the server recovers and stays alive
// across multiple malformed requests on the same lifecycle.
//
// Tags allowed per sub-case:
//   1. empty (no data sent, connection held open until server times out): read-failed or empty-request
//   2. blank request line (\r\n\r\n): malformed-http
//   3. no path (GET\r\n\r\n): malformed-http
//   4. Content-Length but no body: incomplete-body
//   5. binary garbage + \r\n\r\n: malformed-http
//   6. truncated body: incomplete-body
//   7. no HTTP version (GET /health\r\n\r\n): malformed-http

// Raw send+recv: connect, optionally write raw bytes, read whatever comes back.
// If payload is empty, connects without writing and waits for the server to
// respond (server's stream.read() times out → error envelope sent back).
fn _raw_send_recv(port: Int, payload: &String, timeout: conc.Duration) nothrow -> core.Result<String, Int> {
	var addr = net.socket_addr("127.0.0.1", port);
	match net.connect(&addr, timeout) {
		core.Result::Err(_) => { return core.Result::Err(1); },
		core.Result::Ok(conn) => {
			var stream = move conn;
			// Write payload if non-empty
			if payload.byte_length() > 0 {
				val req_bytes = _to_bytes(payload);
				var wbuf = io.buffer(req_bytes.len);
				var i = 0;
				while i < req_bytes.len {
					io.buffer_write(&mut wbuf, i, req_bytes[i]);
					i = i + 1;
				}
				match stream.write(&wbuf, timeout) {
					core.Result::Err(_) => {
						val _ = stream.close(timeout);
						return core.Result::Err(2);
					},
					core.Result::Ok(_) => {}
				}
			}
			// Read response
			var collected: Array<Byte> = [];
			var done = false;
			while !done {
				var rbuf = io.buffer(4096);
				match stream.read(&mut rbuf, timeout) {
					core.Result::Err(_) => { done = true; },
					core.Result::Ok(n) => {
						if n == 0 {
							done = true;
						} else {
							var j = 0;
							while j < n {
								collected.push(io.buffer_read(&mut rbuf, j));
								j = j + 1;
							}
						}
					}
				}
			}
			val _ = stream.close(timeout);
			if collected.len == 0 {
				return core.Result::Err(3);
			}
			return core.Result::Ok(_bytes_to_string(&collected));
		}
	}
}

// Check response against expected status line and at least one of two allowed tags.
// Returns 0 on success, non-zero on failure.
fn _check_malformed_response(resp_str: &String, expected_status: &String, allowed_tag1: &String, allowed_tag2: &String) nothrow -> Int {
	if !_starts_with(resp_str, expected_status) { return 1; }
	val has_tag1 = _contains(resp_str, allowed_tag1);
	if allowed_tag2.byte_length() == 0 {
		if !has_tag1 { return 2; }
	} else {
		val has_tag2 = _contains(resp_str, allowed_tag2);
		if !has_tag1 {
			if !has_tag2 { return 2; }
		}
	}
	return 0;
}

fn scenario_malformed_matrix() nothrow -> Int {
	// Server uses 1s timeout — fast timeout on truncated-body reads, and all
	// other sub-cases complete their reads almost instantly.
	// Client uses 5s timeout — outlives the server's error path.
	val srv_timeout = conc.Duration(millis = 1000);
	val cli_timeout = conc.Duration(millis = 5000);
	val s_400 = "HTTP/1.1 400 Bad Request";
	val t_read_failed = "read-failed";
	val t_empty = "empty-request";
	val t_malformed = "malformed-http";
	val t_incomplete = "incomplete-body";
	val empty = "";

	// Single server for all 7 sub-cases. max_requests = 7.
	var bld = rest.new_app_builder();
	rest.bind(&mut bld, "127.0.0.1", 0);
	match rest.build_app(move bld) {
		core.Result::Err(_) => { return 501; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 502; },
				core.Result::Ok(_) => {}
			}
			match rest_app.add_route(&mut app, "POST", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 503; },
				core.Result::Ok(_) => {}
			}
			match rest.listen_app(&app, cli_timeout) {
				core.Result::Err(_) => { return 504; },
				core.Result::Ok(lst) => {
					var listener = move lst;
					val port = listener.local_port();
					var handle = rest.new_server_handle();
					handle.max_requests = 7;
					var caller_handle = rest.clone_handle(&handle);
					var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy srv_timeout) => {
						return _run_serve(move app, move listener, move handle, srv_timeout);
					});

					// Sub 1: empty — client sends nothing, keeps connection open.
					// Server's stream.read() times out (1s) → read-failed or
					// empty-request. Server writes error response. Client reads it.
					val p1 = "";
					match _raw_send_recv(port, &p1, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 510;
						},
						core.Result::Ok(r1) => {
							val c1 = _check_malformed_response(&r1, &s_400, &t_read_failed, &t_empty);
							if c1 != 0 { return 511; }
						}
					}

					// Sub 2: blank request line (\r\n\r\n only)
					val p2 = "\r\n\r\n";
					match _raw_send_recv(port, &p2, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 520;
						},
						core.Result::Ok(r2) => {
							val c2 = _check_malformed_response(&r2, &s_400, &t_malformed, &empty);
							if c2 != 0 { return 521; }
						}
					}

					// Sub 3: no path (GET\r\n\r\n)
					val p3 = "GET\r\n\r\n";
					match _raw_send_recv(port, &p3, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 530;
						},
						core.Result::Ok(r3) => {
							val c3 = _check_malformed_response(&r3, &s_400, &t_malformed, &empty);
							if c3 != 0 { return 531; }
						}
					}

					// Sub 4: Content-Length declared but no body (server read times out)
					val p4 = "GET / HTTP/1.1\r\nContent-Length: 100\r\n\r\n";
					match _raw_send_recv(port, &p4, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 540;
						},
						core.Result::Ok(r4) => {
							val c4 = _check_malformed_response(&r4, &s_400, &t_incomplete, &empty);
							if c4 != 0 { return 541; }
						}
					}

					// Sub 5: binary garbage + \r\n\r\n
					val p5 = "~~~~~~~~~~~~~~~~~~~~\r\n\r\n";
					match _raw_send_recv(port, &p5, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 550;
						},
						core.Result::Ok(r5) => {
							val c5 = _check_malformed_response(&r5, &s_400, &t_malformed, &empty);
							if c5 != 0 { return 551; }
						}
					}

					// Sub 6: truncated body (Content-Length: 5, only 2 bytes sent)
					val p6 = "POST /health HTTP/1.1\r\nContent-Length: 5\r\n\r\nAB";
					match _raw_send_recv(port, &p6, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 560;
						},
						core.Result::Ok(r6) => {
							val c6 = _check_malformed_response(&r6, &s_400, &t_incomplete, &empty);
							if c6 != 0 { return 561; }
						}
					}

					// Sub 7: no HTTP version (GET /health\r\n\r\n)
					val p7 = "GET /health\r\n\r\n";
					match _raw_send_recv(port, &p7, cli_timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 570;
						},
						core.Result::Ok(r7) => {
							val c7 = _check_malformed_response(&r7, &s_400, &t_malformed, &empty);
							if c7 != 0 { return 571; }
						}
					}

					// All 7 sub-cases done. Server should have self-stopped
					// (max_requests = 7). Stop + join to be safe.
					rest.stop(&caller_handle);
					match sv.join() {
						core.Result::Err(_) => { return 580; },
						core.Result::Ok(exit_code) => {
							if exit_code != 0 { return 581; }
						}
					}
					return 0;
				}
			}
		}
	}
}

// --- Scenario 6: Partial/slow client (600-range) ---
//
// Client sends a valid request in two TCP writes with a 500ms sleep between
// them. Validates that read_request_bytes() correctly accumulates partial
// reads across multiple stream.read() calls without treating a partial
// header as complete. Server timeout (5s) is well above the 500ms delay.

fn _slow_roundtrip(port: Int, part1: &String, part2: &String, timeout: conc.Duration) nothrow -> core.Result<String, Int> {
	var addr = net.socket_addr("127.0.0.1", port);
	match net.connect(&addr, timeout) {
		core.Result::Err(_) => { return core.Result::Err(1); },
		core.Result::Ok(conn) => {
			var stream = move conn;

			// Write first part
			val b1 = _to_bytes(part1);
			var wbuf1 = io.buffer(b1.len);
			var i = 0;
			while i < b1.len {
				io.buffer_write(&mut wbuf1, i, b1[i]);
				i = i + 1;
			}
			match stream.write(&wbuf1, timeout) {
				core.Result::Err(_) => {
					val _ = stream.close(timeout);
					return core.Result::Err(2);
				},
				core.Result::Ok(_) => {}
			}

			// Sleep 500ms between writes
			conc.sleep(conc.Duration(millis = 500));

			// Write second part
			val b2 = _to_bytes(part2);
			var wbuf2 = io.buffer(b2.len);
			var j = 0;
			while j < b2.len {
				io.buffer_write(&mut wbuf2, j, b2[j]);
				j = j + 1;
			}
			match stream.write(&wbuf2, timeout) {
				core.Result::Err(_) => {
					val _ = stream.close(timeout);
					return core.Result::Err(3);
				},
				core.Result::Ok(_) => {}
			}

			// Read response
			var collected: Array<Byte> = [];
			var done = false;
			while !done {
				var rbuf = io.buffer(4096);
				match stream.read(&mut rbuf, timeout) {
					core.Result::Err(_) => { done = true; },
					core.Result::Ok(n) => {
						if n == 0 {
							done = true;
						} else {
							var k = 0;
							while k < n {
								collected.push(io.buffer_read(&mut rbuf, k));
								k = k + 1;
							}
						}
					}
				}
			}
			val _ = stream.close(timeout);
			return core.Result::Ok(_bytes_to_string(&collected));
		}
	}
}

fn scenario_partial_slow_client() nothrow -> Int {
	val timeout = conc.Duration(millis = 5000);

	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 601; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 602; },
				core.Result::Ok(_) => {}
			}
			match rest.listen_app(&app, timeout) {
				core.Result::Err(_) => { return 603; },
				core.Result::Ok(lst) => {
					var listener = move lst;
					val port = listener.local_port();
					var handle = rest.new_server_handle();
					handle.max_requests = 1;
					var caller_handle = rest.clone_handle(&handle);
					var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy timeout) => {
						return _run_serve(move app, move listener, move handle, timeout);
					});

					// Split request: request line in part 1, host header + terminator in part 2
					val part1 = "GET /health HTTP/1.1\r\n";
					val part2 = "Host: localhost\r\nConnection: close\r\n\r\n";
					match _slow_roundtrip(port, &part1, &part2, timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 604;
						},
						core.Result::Ok(resp_str) => {
							rest.stop(&caller_handle);
							match sv.join() {
								core.Result::Err(_) => { return 605; },
								core.Result::Ok(exit_code) => {
									if exit_code != 0 { return 606; }
								}
							}

							val s_200 = "HTTP/1.1 200 OK";
							if !_starts_with(&resp_str, &s_200) { return 607; }
							val m_health = "{\"ok\":true}";
							if !_contains(&resp_str, &m_health) { return 608; }
							return 0;
						}
					}
				}
			}
		}
	}
}

// --- Scenario 7: Large response body (700-range) ---
//
// Handler returns a JSON body >8KB (~12KB of repeated payload). Client reads
// the full response and verifies Content-Length matches actual body length
// and body content is intact via start/end spot checks.

// Build a ~12KB JSON body: {"data":"<repeated 'X' ~12000 chars>"}
// Outer envelope is 10 bytes: {"data":"  ... "}
// So we need ~12000 X chars for ~12010 byte body.
fn _build_large_body() nothrow -> String {
	// Build 100-char block via doubling
	var blk = "XXXXXXXXXX"; // 10
	blk = blk + blk; // 20
	blk = blk + blk; // 40
	blk = blk + blk; // 80
	blk = blk + "XXXXXXXXXXXXXXXXXXXX"; // 100

	// 120 repetitions of 100 chars = 12000 chars
	var payload = "";
	var i = 0;
	while i < 120 {
		payload = payload + blk;
		i = i + 1;
	}
	return "{\"data\":\"" + payload + "\"}";
}

fn _large_handler(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	val body = _build_large_body();
	return core.Result::Ok(rest.json_response(200, body));
}

// Extract substring from index start to end (byte positions).
fn _substr(s: &String, start: Int, end: Int) nothrow -> String {
	val n = end - start;
	if n <= 0 {
		return "";
	}
	var b = io.buffer(n);
	var i = 0;
	while i < n {
		io.buffer_write(&mut b, i, core.string_byte_at(s, start + i));
		i = i + 1;
	}
	return core.string_from_utf8_bytes(io.buffer_ptr(&b), n);
}

// Find \r\n\r\n in string, return index of the first byte after it (body start).
// Returns -1 if not found.
fn _find_body_start(s: &String) nothrow -> Int {
	val len = s.byte_length();
	if len < 4 {
		return -1;
	}
	var i = 0;
	val limit = len - 3;
	while i < limit {
		if core.string_byte_at(s, i) == cast<Byte>(13) {
			if core.string_byte_at(s, i + 1) == cast<Byte>(10) {
				if core.string_byte_at(s, i + 2) == cast<Byte>(13) {
					if core.string_byte_at(s, i + 3) == cast<Byte>(10) {
						return i + 4;
					}
				}
			}
		}
		i = i + 1;
	}
	return -1;
}

// Extract Content-Length value from response header string.
// Returns -1 if not found or unparseable.
fn _extract_content_length(resp: &String) nothrow -> Int {
	val marker = "Content-Length: ";
	val m_len = marker.byte_length();
	val r_len = resp.byte_length();
	if r_len < m_len {
		return -1;
	}
	var i = 0;
	val limit = r_len - m_len;
	while i < limit {
		var matched = true;
		var j = 0;
		while j < m_len {
			if core.string_byte_at(resp, i + j) != core.string_byte_at(marker, j) {
				matched = false;
				j = m_len;
			} else {
				j = j + 1;
			}
		}
		if matched {
			// Found "Content-Length: " at position i. Read digits until \r.
			val val_start = i + m_len;
			var val_end = val_start;
			while val_end < r_len {
				if core.string_byte_at(resp, val_end) == cast<Byte>(13) {
					val_end = val_end; // stop
					// break by jumping past loop
					val_end = val_end + r_len; // force exit
				} else {
					val_end = val_end + 1;
				}
			}
			// Undo the force-exit offset
			if val_end >= r_len {
				val_end = val_end - r_len;
			}
			val val_str = _substr(resp, val_start, val_end);
			match parse.parse_int(val_str) {
				core.Result::Ok(n) => { return n; },
				core.Result::Err(_) => { return -1; }
			}
		}
		i = i + 1;
	}
	return -1;
}

fn scenario_large_response() nothrow -> Int {
	val timeout = conc.Duration(millis = 5000);

	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 701; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/v1/large", core.callback2(_large_handler)) {
				core.Result::Err(_) => { return 702; },
				core.Result::Ok(_) => {}
			}

			var reqs: Array<String> = [];
			var r = "GET /v1/large HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
			reqs.push(move r);
			match _multi_roundtrip(move app, &reqs, timeout) {
				core.Result::Err(_) => { return 703; },
				core.Result::Ok(resps) => {
					if resps.len != 1 { return 704; }

					val resp = &resps[0];

					// Check status line
					val s_200 = "HTTP/1.1 200 OK";
					if !_starts_with(resp, &s_200) { return 705; }

					// Extract Content-Length header
					val cl = _extract_content_length(resp);
					if cl <= 0 { return 706; }

					// Find body start
					val body_start = _find_body_start(resp);
					if body_start == -1 { return 707; }

					// Actual body length = total response length - body_start
					val actual_body_len = resp.byte_length() - body_start;
					if actual_body_len != cl { return 708; }

					// Body should be ~12010 bytes
					if cl < 12000 { return 709; }

					// Spot-check: body starts with {"data":"X
					val body = _substr(resp, body_start, resp.byte_length());
					val prefix = "{\"data\":\"X";
					if !_starts_with(&body, &prefix) { return 710; }

					// Spot-check: body ends with X"}
					val suffix = "X\"}";
					val s_len = suffix.byte_length();
					val b_len = body.byte_length();
					val tail = _substr(&body, b_len - s_len, b_len);
					if tail != suffix { return 711; }

					return 0;
				}
			}
		}
	}
}

// --- Keep-alive TCP helpers ---

fn _find_header_end_bytes(raw: &Array<Byte>) nothrow -> Int {
	val len = raw.len;
	if len < 4 {
		return -1;
	}
	var i = 0;
	val limit = len - 3;
	while i < limit {
		if raw[i] == cast<Byte>(13) {
			if raw[i + 1] == cast<Byte>(10) {
				if raw[i + 2] == cast<Byte>(13) {
					if raw[i + 3] == cast<Byte>(10) {
						return i + 4;
					}
				}
			}
		}
		i = i + 1;
	}
	return -1;
}

fn _scan_cl_from_bytes(raw: &Array<Byte>, header_end: Int) nothrow -> Int {
	val marker = "Content-Length: ";
	val m_len = marker.byte_length();
	if header_end < m_len {
		return -1;
	}
	var i = 0;
	val limit = header_end - m_len;
	while i < limit {
		var matched = true;
		var j = 0;
		while j < m_len {
			if raw[i + j] != core.string_byte_at(marker, j) {
				matched = false;
				j = m_len;
			} else {
				j = j + 1;
			}
		}
		if matched {
			val val_start = i + m_len;
			var val_end = val_start;
			var scanning = true;
			while scanning {
				if val_end >= header_end {
					scanning = false;
				} else {
					if raw[val_end] == cast<Byte>(13) {
						scanning = false;
					} else {
						val_end = val_end + 1;
					}
				}
			}
			var result = 0;
			var k = val_start;
			while k < val_end {
				val d = cast<Int>(raw[k]) - 48;
				if d < 0 { return -1; }
				if d > 9 { return -1; }
				result = result * 10 + d;
				k = k + 1;
			}
			return result;
		}
		i = i + 1;
	}
	return -1;
}

fn _bytes_to_string_range(raw: &Array<Byte>, start: Int, end: Int) nothrow -> String {
	val n = end - start;
	if n <= 0 {
		return "";
	}
	var b = io.buffer(n);
	var i = 0;
	while i < n {
		io.buffer_write(&mut b, i, raw[start + i]);
		i = i + 1;
	}
	return core.string_from_utf8_bytes(io.buffer_ptr(&b), n);
}

// Write raw bytes to a stream.
fn _write_raw(stream: &net.TcpStream, s: &String, timeout: conc.Duration) nothrow -> core.Result<Void, Int> {
	val bytes = _to_bytes(s);
	var wbuf = io.buffer(bytes.len);
	var i = 0;
	while i < bytes.len {
		io.buffer_write(&mut wbuf, i, bytes[i]);
		i = i + 1;
	}
	match stream.write(&wbuf, timeout) {
		core.Result::Err(_) => { return core.Result::Err(1); },
		core.Result::Ok(_) => { return core.Result::Ok(core.void_value()); }
	}
}

// Read one complete HTTP response from keep-alive connection.
fn _read_one_response(stream: &net.TcpStream, buf: &mut Array<Byte>, timeout: conc.Duration) nothrow -> core.Result<String, Int> {
	var header_end = -1;
	var content_length = -1;
	var done = false;

	while !done {
		if header_end == -1 {
			header_end = _find_header_end_bytes(buf);
			if header_end != -1 {
				content_length = _scan_cl_from_bytes(buf, header_end);
			}
		}
		if header_end != -1 {
			if content_length <= 0 {
				done = true;
			} else {
				val body_available = buf.len - header_end;
				if body_available >= content_length {
					done = true;
				}
			}
		}

		if !done {
			var rbuf = io.buffer(4096);
			match stream.read(&mut rbuf, timeout) {
				core.Result::Err(_) => { return core.Result::Err(1); },
				core.Result::Ok(n) => {
					if n == 0 {
						return core.Result::Err(2);
					}
					var j = 0;
					while j < n {
						buf.push(io.buffer_read(&mut rbuf, j));
						j = j + 1;
					}
				}
			}
		}
	}

	var total = header_end;
	if content_length > 0 {
		total = header_end + content_length;
	}
	val resp_str = _bytes_to_string_range(buf, 0, total);

	if total < buf.len {
		var new_buf: Array<Byte> = [];
		var k = total;
		while k < buf.len {
			new_buf.push(buf[k]);
			k = k + 1;
		}
		*buf = move new_buf;
	} else {
		var empty: Array<Byte> = [];
		*buf = move empty;
	}

	return core.Result::Ok(move resp_str);
}

// --- Scenario 8: Keep-alive sustained load (800-range) ---
//
// One TCP connection, 50 requests cycling through 5 types:
// health, echo query, echo body, 404, health again.
// All sent sequentially on the same keep-alive connection.
// Validates correct response for each. Final request uses Connection: close.

fn scenario_keepalive_sustained() nothrow -> Int {
	val timeout = conc.Duration(millis = 10000);
	val total_n = 50;

	var bld = rest.new_app_builder();
	rest.bind(&mut bld, "127.0.0.1", 0);
	match rest.build_app(move bld) {
		core.Result::Err(_) => { return 801; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest_app.add_route(&mut app, "GET", "/health", core.callback2(_health_handler)) {
				core.Result::Err(_) => { return 802; },
				core.Result::Ok(_) => {}
			}
			match rest_app.add_route(&mut app, "GET", "/v1/echo", core.callback2(_echo_query_handler)) {
				core.Result::Err(_) => { return 803; },
				core.Result::Ok(_) => {}
			}
			match rest_app.add_route(&mut app, "POST", "/v1/echo", core.callback2(_echo_body_handler)) {
				core.Result::Err(_) => { return 804; },
				core.Result::Ok(_) => {}
			}

			match rest.listen_app(&app, timeout) {
				core.Result::Err(_) => { return 805; },
				core.Result::Ok(lst) => {
					var listener = move lst;
					val port = listener.local_port();
					var handle = rest.new_server_handle();
					handle.max_requests = total_n;
					var caller_handle = rest.clone_handle(&handle);
					var sv = conc.spawn_cb(| | captures(move app, move listener, move handle, copy timeout) => {
						return _run_serve(move app, move listener, move handle, timeout);
					});

					var addr = net.socket_addr("127.0.0.1", port);
					match net.connect(&addr, timeout) {
						core.Result::Err(_) => {
							rest.stop(&caller_handle);
							val _ = sv.join();
							return 806;
						},
						core.Result::Ok(conn) => {
							var stream = move conn;
							var read_buf: Array<Byte> = [];
							var ok = true;
							var i = 0;

							val s_200 = "HTTP/1.1 200 OK";
							val s_404 = "HTTP/1.1 404 Not Found";
							val m_health = "{\"ok\":true}";
							val m_key = "\"key\":\"stress\"";
							val m_echo = "\"echo\":true";
							val m_notfound = "\"event\":\"not-found\"";

							while i < total_n {
								if ok {
									val kind = i - ((i / 5) * 5);
									var req = "";
									if kind == 0 {
										req = "GET /health HTTP/1.1\r\nHost: localhost\r\n\r\n";
									}
									if kind == 1 {
										req = "GET /v1/echo?key=stress HTTP/1.1\r\nHost: localhost\r\n\r\n";
									}
									if kind == 2 {
										req = "POST /v1/echo HTTP/1.1\r\nHost: localhost\r\nContent-Length: 15\r\n\r\n{\"test\":\"body\"}";
									}
									if kind == 3 {
										req = "GET /nonexistent HTTP/1.1\r\nHost: localhost\r\n\r\n";
									}
									if kind == 4 {
										// Last cycle gets Connection: close on final request
										if i == total_n - 1 {
											req = "GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
										} else {
											req = "GET /health HTTP/1.1\r\nHost: localhost\r\n\r\n";
										}
									}

									match _write_raw(&stream, &req, timeout) {
										core.Result::Err(_) => { ok = false; },
										core.Result::Ok(_) => {}
									}

									if ok {
										match _read_one_response(&stream, &mut read_buf, timeout) {
											core.Result::Err(_) => { ok = false; },
											core.Result::Ok(resp) => {
												if kind == 0 {
													if !_starts_with(&resp, &s_200) { ok = false; }
													if ok {
														if !_contains(&resp, &m_health) { ok = false; }
													}
												}
												if kind == 1 {
													if !_starts_with(&resp, &s_200) { ok = false; }
													if ok {
														if !_contains(&resp, &m_key) { ok = false; }
													}
												}
												if kind == 2 {
													if !_starts_with(&resp, &s_200) { ok = false; }
													if ok {
														if !_contains(&resp, &m_echo) { ok = false; }
													}
												}
												if kind == 3 {
													if !_starts_with(&resp, &s_404) { ok = false; }
													if ok {
														if !_contains(&resp, &m_notfound) { ok = false; }
													}
												}
												if kind == 4 {
													if !_starts_with(&resp, &s_200) { ok = false; }
													if ok {
														if !_contains(&resp, &m_health) { ok = false; }
													}
												}
											}
										}
									}
								}
								i = i + 1;
							}

							val _ = stream.close(timeout);
							rest.stop(&caller_handle);
							match sv.join() {
								core.Result::Err(_) => { return 810; },
								core.Result::Ok(exit_code) => {
									if exit_code != 0 { return 811; }
								}
							}

							if !ok { return 820; }
							return 0;
						}
					}
				}
			}
		}
	}
}

fn main() nothrow -> Int {
	val a = scenario_many_sequential_mixed();
	if a != 0 { return a; }
	val b = scenario_concurrent_clients();
	if b != 0 { return b; }
	val c = scenario_start_stop_cycles();
	if c != 0 { return c; }
	val d = scenario_large_headers();
	if d != 0 { return d; }
	val e = scenario_malformed_matrix();
	if e != 0 { return e; }
	val f = scenario_partial_slow_client();
	if f != 0 { return f; }
	val g = scenario_large_response();
	if g != 0 { return g; }
	val h = scenario_keepalive_sustained();
	if h != 0 { return h; }
	return 0;
}
