module web.rest.tests.unit.middleware_test;

import std.core as core;
import std.concurrent as conc;
import web.rest as rest;
import web.rest.events as events;

// Test-only exception type. Not one of the cataloged web.rest.events types,
// so _dispatch_throws's catch-all path takes over and converts to
// Err(500, "internal", "internal-error", ...).
pub error TestUnknownException {
	tag: String,
}

// Validation tests for global add_middleware + onion-fold dispatch (web-rest 0.4).
// Covers spec validation cases 1-5 (single mw, composition, handler-throws-typed,
// handler-throws-unknown, short-circuit) and case 10 (Ok->Err / Err->Ok transformations).
// Runs under plain + ASAN + memcheck via `just test`.

// --- Tracing payload ---
//
// Each middleware/handler appends an event tag to a Trace stashed in Context
// via ctx_set / ctx_take. Final assertion compares trace to expected sequence.
struct Trace { pub events: Array<String> }

fn _trace_push(ctx: &mut rest.Context, tag: String) nothrow -> Void {
	var evs: Array<String> = [];
	match rest.ctx_take<type Trace>(ctx) {
		Optional::Some(t) => {
			var taken = move t;
			val n = taken.events.len;
			var i = 0;
			while i < n {
				evs.push(taken.events[i].clone());
				i = i + 1;
			}
		},
		Optional::None => {}
	}
	evs.push(move tag);
	rest.ctx_set<type Trace>(ctx, Trace(events = move evs));
	return core.void_value();
}

fn _trace_eq(actual: &Array<String>, expected: &Array<String>) nothrow -> Bool {
	if actual.len != expected.len { return false; }
	var i = 0;
	while i < actual.len {
		if actual[i] != expected[i] { return false; }
		i = i + 1;
	}
	return true;
}

// --- Helpers ---

fn _build_test_app() nothrow -> rest.App {
	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 8080);
	match rest.build_app(move b) {
		core.Result::Ok(a) => { return move a; },
		core.Result::Err(_) => { return _unreachable_app(); }
	}
}

fn _unreachable_app() nothrow -> rest.App {
	var b = rest.new_app_builder();
	rest.bind(&mut b, "0.0.0.0", 1);
	match rest.build_app(move b) {
		core.Result::Ok(a) => { return move a; },
		core.Result::Err(_) => { return _unreachable_app(); }
	}
}

fn _no_fields() nothrow -> String {
	return "{}";
}

// --- Handlers ---

fn _ok_handler(req: &rest.Request, ctx: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	_trace_push(ctx, "H:enter");
	val resp = rest.json_response(200, "{\"ok\":true}");
	_trace_push(ctx, "H:exit");
	return core.Result::Ok(move resp);
}

fn _bad_request_throws_handler(req: &rest.Request, ctx: &mut rest.Context) -> rest.Response {
	_trace_push(ctx, "H:enter");
	throw events:RestBadRequest(tag = "h-bad", message = "handler bad request", fields_json = _no_fields());
}

fn _unknown_throws_handler(req: &rest.Request, ctx: &mut rest.Context) -> rest.Response {
	_trace_push(ctx, "H:enter");
	throw TestUnknownException(tag = "h-unknown");
}

// --- Scenario 100: single middleware passthrough ---
// One mw, records pre+post, observes handler's Ok result.
fn scenario_single_middleware_passthrough() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "A:enter");
		val result = next.call(r, c);
		_trace_push(c, "A:exit");
		return move result;
	});
	match rest.add_route(&mut app, "GET", "/", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 101; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 102; },
		core.Result::Ok(resp) => {
			if resp.status != 200 { return 103; }
		}
	}
	val expected: Array<String> = ["A:enter", "H:enter", "H:exit", "A:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 104; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 105; }
		}
	}
	return 0;
}

// --- Scenario 200: composition — outside-in entry, inside-out exit ---
// Two mws (M1 outer, M2 inner). Trace must be:
//   M1:enter, M2:enter, H, M2:exit, M1:exit
// M1 is registered first (registration order = outside-in).
fn scenario_composition_order() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "M1:enter");
		val result = next.call(r, c);
		_trace_push(c, "M1:exit");
		return move result;
	});
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "M2:enter");
		val result = next.call(r, c);
		_trace_push(c, "M2:exit");
		return move result;
	});
	match rest.add_route(&mut app, "GET", "/", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 201; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 202; },
		core.Result::Ok(_) => {}
	}
	val expected: Array<String> = ["M1:enter", "M2:enter", "H:enter", "H:exit", "M2:exit", "M1:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 203; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 204; }
		}
	}
	return 0;
}

// --- Scenario 300: handler throws typed RestException → mw sees Err ---
// Handler throws RestBadRequest. Framework's _dispatch_throws adapter
// converts to Err(400, "request-invalid", "h-bad", ...).
// Middleware's next.call(...) returns this Err; post-work still runs.
fn scenario_handler_throws_typed() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "A:enter");
		val result = next.call(r, c);
		_trace_push(c, "A:exit");
		return move result;
	});
	match rest.add_throws_route(&mut app, "POST", "/bad", core.callback_throw2(_bad_request_throws_handler)) {
		core.Result::Err(_) => { return 301; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("POST", "/bad");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Ok(_) => { return 302; },
		core.Result::Err(e) => {
			if e.status != 400 { return 303; }
			if e.tag != "h-bad" { return 304; }
		}
	}
	// Post-work ran even though handler threw — A:exit must be in the trace.
	val expected: Array<String> = ["A:enter", "H:enter", "A:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 305; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 306; }
		}
	}
	return 0;
}

// --- Scenario 400: handler throws unknown exception → mw sees Err(500) ---
// Framework's _dispatch_throws catch-all converts to Err(internal-error 500).
fn scenario_handler_throws_unknown() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "A:enter");
		val result = next.call(r, c);
		_trace_push(c, "A:exit");
		return move result;
	});
	match rest.add_throws_route(&mut app, "GET", "/boom", core.callback_throw2(_unknown_throws_handler)) {
		core.Result::Err(_) => { return 401; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/boom");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Ok(_) => { return 402; },
		core.Result::Err(e) => {
			if e.status != 500 { return 403; }
			if e.tag != "internal-error" { return 404; }
		}
	}
	val expected: Array<String> = ["A:enter", "H:enter", "A:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 405; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 406; }
		}
	}
	return 0;
}

// --- Scenario 500: short-circuit — mw returns Err without calling next ---
// Inner mw returns Err(401) without calling next.  Handler must not run.
// Outer mw observes the short-circuit Result and post-work runs.
fn scenario_short_circuit_no_next() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "OUTER:enter");
		val result = next.call(r, c);
		_trace_push(c, "OUTER:exit");
		return move result;
	});
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "INNER:short-circuit");
		val _unused = move next;   // explicitly drop next without calling
		return core.Result::Err(rest.rest_error(401, "unauthorized", "mw-blocked", "blocked by inner mw"));
	});
	match rest.add_route(&mut app, "GET", "/", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 501; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Ok(_) => { return 502; },
		core.Result::Err(e) => {
			if e.status != 401 { return 503; }
			if e.tag != "mw-blocked" { return 504; }
		}
	}
	// Handler must not have run — no "H:enter" / "H:exit" in trace.
	val expected: Array<String> = ["OUTER:enter", "INNER:short-circuit", "OUTER:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 505; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 506; }
		}
	}
	return 0;
}

// --- Scenario 600: Ok -> Err transformation ---
// Inner handler returns Ok(200). Outer mw inspects the Result and converts
// to Err(422). Caller sees the transformed Err.
fn scenario_transform_ok_to_err() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		val result = next.call(r, c);
		match move result {
			core.Result::Ok(_) => {
				return core.Result::Err(rest.rest_error(422, "request-invalid", "mw-flagged", "flagged by mw"));
			},
			core.Result::Err(e) => { return core.Result::Err(move e); }
		}
	});
	match rest.add_route(&mut app, "GET", "/", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 601; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Ok(_) => { return 602; },
		core.Result::Err(e) => {
			if e.status != 422 { return 603; }
			if e.tag != "mw-flagged" { return 604; }
		}
	}
	return 0;
}

// --- Scenario 700: Err -> Ok transformation ---
// Inner handler throws RestUnauthorized → framework converts to Err(401).
// Outer mw catches the known error class and substitutes a 200 response.
fn scenario_transform_err_to_ok() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		val result = next.call(r, c);
		match move result {
			core.Result::Err(_) => {
				return core.Result::Ok(rest.json_response(200, "{\"recovered\":true}"));
			},
			core.Result::Ok(resp) => { return core.Result::Ok(move resp); }
		}
	});
	match rest.add_throws_route(&mut app, "POST", "/bad", core.callback_throw2(_bad_request_throws_handler)) {
		core.Result::Err(_) => { return 701; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("POST", "/bad");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 702; },
		core.Result::Ok(resp) => {
			if resp.status != 200 { return 703; }
			if resp.body != "{\"recovered\":true}" { return 704; }
		}
	}
	return 0;
}

// --- Scenario 750a: route-group middleware fires only for routes in that group ---
// Two routes — one in /grp, one at /. One group-mw on /grp, no globals.
// /grp/X: trace must include the group-mw enter/exit.
// /:     trace must NOT include the group-mw enter/exit (different group, no match).
fn scenario_group_middleware_only_fires_in_group() nothrow -> Int {
	var app = _build_test_app();
	match rest.add_route_group(&mut app, "/grp") {
		core.Result::Err(_) => { return 751; },
		core.Result::Ok(rg) => {
			rest.add_route_group_middleware(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "GROUP:enter");
				val result = next.call(r, c);
				_trace_push(c, "GROUP:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg, "GET", "/in", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 752; },
				core.Result::Ok(_) => {}
			}
		}
	}
	match rest.add_route(&mut app, "GET", "/out", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 753; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);

	// /grp/in — group mw should fire
	var req_in = rest.new_request("GET", "/grp/in");
	var ctx_in = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_in, &mut ctx_in) {
		core.Result::Err(_) => { return 754; },
		core.Result::Ok(_) => {}
	}
	val expected_in: Array<String> = ["GROUP:enter", "H:enter", "H:exit", "GROUP:exit"];
	match rest.ctx_get<type Trace>(&ctx_in) {
		Optional::None => { return 755; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_in) { return 756; } }
	}

	// /out — group mw must NOT fire
	var req_out = rest.new_request("GET", "/out");
	var ctx_out = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_out, &mut ctx_out) {
		core.Result::Err(_) => { return 757; },
		core.Result::Ok(_) => {}
	}
	val expected_out: Array<String> = ["H:enter", "H:exit"];
	match rest.ctx_get<type Trace>(&ctx_out) {
		Optional::None => { return 758; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_out) { return 759; } }
	}
	return 0;
}

// --- Scenario 750b: full composition — guard + global mw + group mw + handler ---
// For an in-group route, dispatch order is:
//   group guard → onion (global mw outer, group mw inner) → handler
// Trace verifies the guard runs first and the onion folds outside-in
// across the combined globals + matched group middleware in registration order.
fn scenario_global_plus_group_mw_composition() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "GLOBAL:enter");
		val result = next.call(r, c);
		_trace_push(c, "GLOBAL:exit");
		return move result;
	});
	match rest.add_route_group(&mut app, "/api") {
		core.Result::Err(_) => { return 761; },
		core.Result::Ok(rg) => {
			rest.add_route_group_guard(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context| => {
				_trace_push(c, "GUARD");
				return core.Result::Ok(core.void_value());
			});
			rest.add_route_group_middleware(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "GROUP:enter");
				val result = next.call(r, c);
				_trace_push(c, "GROUP:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg, "GET", "/x", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 762; },
				core.Result::Ok(_) => {}
			}
		}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/api/x");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 763; },
		core.Result::Ok(_) => {}
	}
	// Guard runs before the onion. Onion: GLOBAL is registered before GROUP, so
	// GLOBAL is outer, GROUP is inner.
	val expected: Array<String> = ["GUARD", "GLOBAL:enter", "GROUP:enter", "H:enter", "H:exit", "GROUP:exit", "GLOBAL:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 764; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected) { return 765; } }
	}
	return 0;
}

// --- Scenario 800: zero-middleware fast path ---
// No middleware registered. Dispatch must still run and call the handler.
fn scenario_zero_middleware_fast_path() nothrow -> Int {
	var app = _build_test_app();
	match rest.add_route(&mut app, "GET", "/", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 801; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 802; },
		core.Result::Ok(resp) => {
			if resp.status != 200 { return 803; }
		}
	}
	val expected: Array<String> = ["H:enter", "H:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 804; },
		Optional::Some(t) => {
			if !_trace_eq(&t.events, &expected) { return 805; }
		}
	}
	return 0;
}

// --- Scenario 1100: guard rejection short-circuits before any middleware runs ---
// Route is in a group whose guard returns Err. A global mw and a group mw are
// registered, but neither must execute — the guard runs before the onion.
fn scenario_guard_rejection_skips_middleware() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "GLOBAL:enter");
		val result = next.call(r, c);
		_trace_push(c, "GLOBAL:exit");
		return move result;
	});
	match rest.add_route_group(&mut app, "/api") {
		core.Result::Err(_) => { return 1101; },
		core.Result::Ok(rg) => {
			rest.add_route_group_guard(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context| => {
				_trace_push(c, "GUARD:reject");
				return core.Result::Err(rest.rest_error(403, "forbidden", "guard-block", "blocked by guard"));
			});
			rest.add_route_group_middleware(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "GROUP:enter");
				val result = next.call(r, c);
				_trace_push(c, "GROUP:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg, "GET", "/x", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 1102; },
				core.Result::Ok(_) => {}
			}
		}
	}
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/api/x");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Ok(_) => { return 1103; },
		core.Result::Err(e) => {
			if e.status != 403 { return 1104; }
			if e.tag != "guard-block" { return 1105; }
		}
	}
	val expected: Array<String> = ["GUARD:reject"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 1106; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected) { return 1107; } }
	}
	return 0;
}

// --- Scenario 1200: registration-order interleaving (group before global) ---
// Per the design invariant ("registration order across the whole app determines
// layering"), a group middleware registered BEFORE a global middleware places
// the group middleware OUTSIDE the global one for routes in that group.
fn scenario_group_before_global_layering() nothrow -> Int {
	var app = _build_test_app();
	match rest.add_route_group(&mut app, "/api") {
		core.Result::Err(_) => { return 1201; },
		core.Result::Ok(rg) => {
			// Group mw FIRST.
			rest.add_route_group_middleware(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "GROUP:enter");
				val result = next.call(r, c);
				_trace_push(c, "GROUP:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg, "GET", "/x", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 1202; },
				core.Result::Ok(_) => {}
			}
		}
	}
	// Global mw SECOND — should be inner.
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "GLOBAL:enter");
		val result = next.call(r, c);
		_trace_push(c, "GLOBAL:exit");
		return move result;
	});
	val app_arc = conc.arc(move app);
	var req = rest.new_request("GET", "/api/x");
	var ctx = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req, &mut ctx) {
		core.Result::Err(_) => { return 1203; },
		core.Result::Ok(_) => {}
	}
	// GROUP outer, GLOBAL inner.
	val expected: Array<String> = ["GROUP:enter", "GLOBAL:enter", "H:enter", "H:exit", "GLOBAL:exit", "GROUP:exit"];
	match rest.ctx_get<type Trace>(&ctx) {
		Optional::None => { return 1204; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected) { return 1205; } }
	}
	return 0;
}

// --- Scenario 1300: multiple route groups — only matched group fires ---
// Two RouteGroups (/a, /b), each with its own mw. One global mw on top.
// Dispatch /a/x: GLOBAL + A-mw fire; B-mw doesn't.
// Dispatch /b/x: GLOBAL + B-mw fire; A-mw doesn't.
fn scenario_multiple_route_groups_isolation() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "G:enter");
		val result = next.call(r, c);
		_trace_push(c, "G:exit");
		return move result;
	});
	match rest.add_route_group(&mut app, "/a") {
		core.Result::Err(_) => { return 1301; },
		core.Result::Ok(rg_a) => {
			rest.add_route_group_middleware(&mut app, &rg_a, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "A:enter");
				val result = next.call(r, c);
				_trace_push(c, "A:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg_a, "GET", "/x", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 1302; },
				core.Result::Ok(_) => {}
			}
		}
	}
	match rest.add_route_group(&mut app, "/b") {
		core.Result::Err(_) => { return 1303; },
		core.Result::Ok(rg_b) => {
			rest.add_route_group_middleware(&mut app, &rg_b, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "B:enter");
				val result = next.call(r, c);
				_trace_push(c, "B:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg_b, "GET", "/x", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 1304; },
				core.Result::Ok(_) => {}
			}
		}
	}
	val app_arc = conc.arc(move app);

	// /a/x: GLOBAL outer, A inner — B does not appear.
	var req_a = rest.new_request("GET", "/a/x");
	var ctx_a = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_a, &mut ctx_a) {
		core.Result::Err(_) => { return 1305; },
		core.Result::Ok(_) => {}
	}
	val expected_a: Array<String> = ["G:enter", "A:enter", "H:enter", "H:exit", "A:exit", "G:exit"];
	match rest.ctx_get<type Trace>(&ctx_a) {
		Optional::None => { return 1306; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_a) { return 1307; } }
	}

	// /b/x: GLOBAL outer, B inner — A does not appear.
	var req_b = rest.new_request("GET", "/b/x");
	var ctx_b = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_b, &mut ctx_b) {
		core.Result::Err(_) => { return 1308; },
		core.Result::Ok(_) => {}
	}
	val expected_b: Array<String> = ["G:enter", "B:enter", "H:enter", "H:exit", "B:exit", "G:exit"];
	match rest.ctx_get<type Trace>(&ctx_b) {
		Optional::None => { return 1309; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_b) { return 1310; } }
	}
	return 0;
}

// --- Scenario 1400: group-of-one (per-route middleware replacement) ---
// The recommended pattern when one specific route needs its own middleware:
// put it in a single-route RouteGroup and attach the middleware there.
fn scenario_group_of_one_pattern() nothrow -> Int {
	var app = _build_test_app();
	// Group containing exactly one route at /admin/dashboard.
	match rest.add_route_group(&mut app, "/admin/dashboard") {
		core.Result::Err(_) => { return 1401; },
		core.Result::Ok(rg) => {
			rest.add_route_group_middleware(&mut app, &rg, |r: &rest.Request, c: &mut rest.Context, next| => {
				_trace_push(c, "ADMIN:enter");
				val result = next.call(r, c);
				_trace_push(c, "ADMIN:exit");
				return move result;
			});
			match rest.add_route_group_route(&mut app, &rg, "GET", "/", core.callback2(_ok_handler)) {
				core.Result::Err(_) => { return 1402; },
				core.Result::Ok(_) => {}
			}
		}
	}
	// Sibling unrelated route — proves the group-mw is scoped to the single route.
	match rest.add_route(&mut app, "GET", "/health", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 1403; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);

	var req_in = rest.new_request("GET", "/admin/dashboard");
	var ctx_in = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_in, &mut ctx_in) {
		core.Result::Err(_) => { return 1404; },
		core.Result::Ok(_) => {}
	}
	val expected_in: Array<String> = ["ADMIN:enter", "H:enter", "H:exit", "ADMIN:exit"];
	match rest.ctx_get<type Trace>(&ctx_in) {
		Optional::None => { return 1405; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_in) { return 1406; } }
	}

	var req_out = rest.new_request("GET", "/health");
	var ctx_out = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_out, &mut ctx_out) {
		core.Result::Err(_) => { return 1407; },
		core.Result::Ok(_) => {}
	}
	val expected_out: Array<String> = ["H:enter", "H:exit"];
	match rest.ctx_get<type Trace>(&ctx_out) {
		Optional::None => { return 1408; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_out) { return 1409; } }
	}
	return 0;
}

// --- Scenario 1500: mixed throws + nothrow handlers under the same middleware ---
// One mw wraps both a nothrow route and a throws route.  The mw's `next.call`
// must observe Ok from the nothrow handler and Err (after _dispatch_throws)
// from the throws handler — both go through the same onion implementation.
fn scenario_mixed_throws_and_nothrow_routes() nothrow -> Int {
	var app = _build_test_app();
	rest.add_middleware(&mut app, |r: &rest.Request, c: &mut rest.Context, next| => {
		_trace_push(c, "MW:enter");
		val result = next.call(r, c);
		match &result {
			core.Result::Ok(_) => { _trace_push(c, "MW:saw-ok"); },
			core.Result::Err(_) => { _trace_push(c, "MW:saw-err"); }
		}
		_trace_push(c, "MW:exit");
		return move result;
	});
	match rest.add_route(&mut app, "GET", "/ok", core.callback2(_ok_handler)) {
		core.Result::Err(_) => { return 1501; },
		core.Result::Ok(_) => {}
	}
	match rest.add_throws_route(&mut app, "POST", "/bad", core.callback_throw2(_bad_request_throws_handler)) {
		core.Result::Err(_) => { return 1502; },
		core.Result::Ok(_) => {}
	}
	val app_arc = conc.arc(move app);

	// Nothrow route → mw observes Ok.
	var req_ok = rest.new_request("GET", "/ok");
	var ctx_ok = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_ok, &mut ctx_ok) {
		core.Result::Err(_) => { return 1503; },
		core.Result::Ok(_) => {}
	}
	val expected_ok: Array<String> = ["MW:enter", "H:enter", "H:exit", "MW:saw-ok", "MW:exit"];
	match rest.ctx_get<type Trace>(&ctx_ok) {
		Optional::None => { return 1504; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_ok) { return 1505; } }
	}

	// Throws route → framework converts to Err; mw observes Err.
	var req_bad = rest.new_request("POST", "/bad");
	var ctx_bad = rest.new_context();
	match rest.dispatch(app_arc.clone(), &mut req_bad, &mut ctx_bad) {
		core.Result::Ok(_) => { return 1506; },
		core.Result::Err(e) => {
			if e.status != 400 { return 1507; }
			if e.tag != "h-bad" { return 1508; }
		}
	}
	val expected_bad: Array<String> = ["MW:enter", "H:enter", "MW:saw-err", "MW:exit"];
	match rest.ctx_get<type Trace>(&ctx_bad) {
		Optional::None => { return 1509; },
		Optional::Some(t) => { if !_trace_eq(&t.events, &expected_bad) { return 1510; } }
	}
	return 0;
}

fn main() nothrow -> Int {
	val r1 = scenario_single_middleware_passthrough();
	if r1 != 0 { return r1; }

	val r2 = scenario_composition_order();
	if r2 != 0 { return r2; }

	val r3 = scenario_handler_throws_typed();
	if r3 != 0 { return r3; }

	val r4 = scenario_handler_throws_unknown();
	if r4 != 0 { return r4; }

	val r5 = scenario_short_circuit_no_next();
	if r5 != 0 { return r5; }

	val r6 = scenario_transform_ok_to_err();
	if r6 != 0 { return r6; }

	val r7 = scenario_transform_err_to_ok();
	if r7 != 0 { return r7; }

	val r8 = scenario_zero_middleware_fast_path();
	if r8 != 0 { return r8; }

	val r9 = scenario_group_middleware_only_fires_in_group();
	if r9 != 0 { return r9; }

	val r10 = scenario_global_plus_group_mw_composition();
	if r10 != 0 { return r10; }

	val r11 = scenario_guard_rejection_skips_middleware();
	if r11 != 0 { return r11; }

	val r12 = scenario_group_before_global_layering();
	if r12 != 0 { return r12; }

	val r13 = scenario_multiple_route_groups_isolation();
	if r13 != 0 { return r13; }

	val r14 = scenario_group_of_one_pattern();
	if r14 != 0 { return r14; }

	val r15 = scenario_mixed_throws_and_nothrow_routes();
	if r15 != 0 { return r15; }

	return 0;
}
