// --- json_string (optional) ---

fn test_json_string_present() nothrow -> Int {
	val text = "{\"name\":\"bob\"}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 4001; },
		core.Result::Ok(node) => {
			match rest.json_string(&node, "name") {
				Optional::None => { return 4002; },
				Optional::Some(v) => {
					if v != "bob" { return 4003; }
					return 0;
				}
			}
		}
	}
}

fn test_json_string_missing() nothrow -> Int {
	val text = "{\"age\":42}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 4101; },
		core.Result::Ok(node) => {
			match rest.json_string(&node, "name") {
				Optional::Some(_) => { return 4102; },
				Optional::None => { return 0; }
			}
		}
	}
}

fn test_json_string_wrong_type() nothrow -> Int {
	val text = "{\"name\":42}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 4201; },
		core.Result::Ok(node) => {
			match rest.json_string(&node, "name") {
				Optional::Some(_) => { return 4202; },
				Optional::None => { return 0; }
			}
		}
	}
}

// --- json_int (optional) ---

fn test_json_int_present() nothrow -> Int {
	val text = "{\"age\":99}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 5001; },
		core.Result::Ok(node) => {
			match rest.json_int(&node, "age") {
				Optional::None => { return 5002; },
				Optional::Some(v) => {
					if v != 99 { return 5003; }
					return 0;
				}
			}
		}
	}
}

fn test_json_int_missing() nothrow -> Int {
	val text = "{\"name\":\"alice\"}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 5101; },
		core.Result::Ok(node) => {
			match rest.json_int(&node, "age") {
				Optional::Some(_) => { return 5102; },
				Optional::None => { return 0; }
			}
		}
	}
}

fn test_json_int_wrong_type() nothrow -> Int {
	val text = "{\"age\":\"not-a-number\"}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 5201; },
		core.Result::Ok(node) => {
			match rest.json_int(&node, "age") {
				Optional::Some(_) => { return 5202; },
				Optional::None => { return 0; }
			}
		}
	}
}

fn main() nothrow -> Int {
	// require_json_string
	val r1 = test_require_json_string_ok();
	if r1 != 0 { return r1; }
	val r2 = test_require_json_string_missing();
	if r2 != 0 { return r2; }
	val r3 = test_require_json_string_wrong_type();
	if r3 != 0 { return r3; }

	// require_json_int
	val r4 = test_require_json_int_ok();
	if r4 != 0 { return r4; }
	val r5 = test_require_json_int_missing();
	if r5 != 0 { return r5; }
	val r6 = test_require_json_int_wrong_type();
	if r6 != 0 { return r6; }

	// require_json_bool
	val r7 = test_require_json_bool_ok();
	if r7 != 0 { return r7; }
	val r8 = test_require_json_bool_false();
	if r8 != 0 { return r8; }
	val r9 = test_require_json_bool_missing();
	if r9 != 0 { return r9; }
	val r10 = test_require_json_bool_wrong_type();
	if r10 != 0 { return r10; }

	// json_string
	val r11 = test_json_string_present();
	if r11 != 0 { return r11; }
	val r12 = test_json_string_missing();
	if r12 != 0 { return r12; }
	val r13 = test_json_string_wrong_type();
	if r13 != 0 { return r13; }

	// json_int
	val r14 = test_json_int_present();
	if r14 != 0 { return r14; }
	val r15 = test_json_int_missing();
	if r15 != 0 { return r15; }
	val r16 = test_json_int_wrong_type();
	if r16 != 0 { return r16; }

	return 0;
}
