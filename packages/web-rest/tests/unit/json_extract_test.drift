module web.rest.tests.unit.json_extract_test

import std.core as core;
import std.json as json;
import web.rest as rest;

// --- require_json_string ---

fn test_require_json_string_ok() nothrow -> Int {
	val text = "{\"name\":\"alice\"}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 1001; },
		core.Result::Ok(node) => {
			match rest.require_json_string(&node, "name") {
				core.Result::Err(_) => { return 1002; },
				core.Result::Ok(v) => {
					if v != "alice" { return 1003; }
					return 0;
				}
			}
		}
	}
}

fn test_require_json_string_missing() nothrow -> Int {
	val text = "{\"age\":42}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 1101; },
		core.Result::Ok(node) => {
			match rest.require_json_string(&node, "name") {
				core.Result::Ok(_) => { return 1102; },
				core.Result::Err(e) => {
					if e.status != 400 { return 1103; }
					if e.event != "request-invalid" { return 1104; }
					if e.tag != "missing-field" { return 1105; }
					if e.field_keys.len != 1 { return 1106; }
					if e.field_keys[0] != "name" { return 1107; }
					if e.field_values[0] != "missing-field" { return 1108; }
					return 0;
				}
			}
		}
	}
}

fn test_require_json_string_wrong_type() nothrow -> Int {
	val text = "{\"name\":123}";
	match json.parse(&text) {
		core.Result::Err(_) => { return 1201; },
		core.Result::Ok(node) => {
			match rest.require_json_string(&node, "name") {
				core.Result::Ok(_) => { return 1202; },
				core.Result::Err(e) => {
					if e.tag != "invalid-type" { return 1203; }
					if e.field_keys.len != 1 { return 1204; }
					if e.field_keys[0] != "name" { return 1205; }
					if e.field_values[0] != "invalid-type" { return 1206; }
					return 0;
				}
			}
		}
	}
}

