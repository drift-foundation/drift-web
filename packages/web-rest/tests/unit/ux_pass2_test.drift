module web.rest.tests.unit.ux_pass2_test;

import std.core as core;
import std.json as json;
import std.parse as parse;
import web.rest as rest;
import web.rest.request as request;

// UX Pass 2 acceptance tests — 7 scenarios from work/rest-next/plan.md.
// Stories 1–7: acceptance tests. Story 6: body parse caching with JsonHandle.
// Full gap report: work/rest/progress.md.

// --- Story 1: Malformed JSON body → 400 request-invalid, tag=malformed-json ---
// Gap: none — body_json() already returns this.

fn scenario_malformed_json_body() nothrow -> Int {
	var req = rest.new_request("POST", "/v1/users");
	req.body = "{not json";
	match rest.body_json(&req) {
		core.Result::Ok(_) => { return 101; },
		core.Result::Err(e) => {
			if e.status != 400 { return 102; }
			if e.event != "request-invalid" { return 103; }
			if e.tag != "malformed-json" { return 104; }
			return 0;
		}
	}
}

// --- Story 2: Missing email + invalid age → 400, tag=validation-failed, two field errors ---
// Acceptance test: uses require_json_string()/require_json_int() helpers.

fn scenario_validation_fields_email_age() nothrow -> Int {
	var req = rest.new_request("POST", "/v1/users");
	req.body = "{\"age\":\"not-a-number\"}";
	match rest.body_json(&req) {
		core.Result::Err(_) => { return 201; },
		core.Result::Ok(handle) => {
			val node = handle.node();
			var err = rest.rest_error(400, "request-invalid", "validation-failed", "input validation failed");

			// Check email — missing field. Verify helper's own field entry.
			match rest.require_json_string(node, "email") {
				core.Result::Ok(_) => { return 202; },
				core.Result::Err(field_err) => {
					if field_err.tag != "missing-field" { return 217; }
					if field_err.fields_json != "{\"email\":\"missing-field\"}" { return 219; }
					rest.add_field(&mut err, "email", "missing-field");
				}
			}

			// Check age — present but wrong type (string, not int). Verify helper's own field entry.
			match rest.require_json_int(node, "age") {
				core.Result::Ok(_) => { return 204; },
				core.Result::Err(field_err) => {
					if field_err.tag != "invalid-type" { return 218; }
					if field_err.fields_json != "{\"age\":\"invalid-type\"}" { return 222; }
					rest.add_field(&mut err, "age", "invalid-type");
				}
			}

			// Build envelope and verify.
			val event_id = "evt-ux2-s2";
			val resp = rest.error_envelope(&err, &event_id);
			if resp.status != 400 { return 205; }
			match json.parse(&resp.body) {
				core.Result::Err(_) => { return 206; },
				core.Result::Ok(env) => {
					// tag = validation-failed
					val tag_key = "tag";
					match env.get(&tag_key) {
						Optional::None => { return 207; },
						Optional::Some(tg) => {
							match tg.as_string() {
								Optional::None => { return 208; },
								Optional::Some(v) => {
									if v != "validation-failed" { return 209; }
								}
							}
						}
					}
					// fields.email = missing-field
					val fields_key = "fields";
					match env.get(&fields_key) {
						Optional::None => { return 210; },
						Optional::Some(fields) => {
							val ek = "email";
							match fields.get(&ek) {
								Optional::None => { return 211; },
								Optional::Some(ev) => {
									match ev.as_string() {
										Optional::None => { return 212; },
										Optional::Some(v) => {
											if v != "missing-field" { return 213; }
										}
									}
								}
							}
							// fields.age = invalid-type
							val ak = "age";
							match fields.get(&ak) {
								Optional::None => { return 214; },
								Optional::Some(av) => {
									match av.as_string() {
										Optional::None => { return 215; },
										Optional::Some(v) => {
											if v != "invalid-type" { return 216; }
										}
									}
								}
							}
							return 0;
						}
					}
				}
			}
		}
	}
}

// --- Story 3: Path string extraction + shared int validation ---
// Acceptance test: uses path_param() → validate_int().

fn scenario_path_int_query_default() nothrow -> Int {
	var req = rest.new_request("GET", "/v1/users/42");
	rest.add_path_param(&mut req, "id", "42");
	rest.add_query_param(&mut req, "page", "2");

	// Path int: path_param → validate_int.
	val id_key = "id";
	match rest.path_param(&req, &id_key) {
		core.Result::Err(_) => { return 301; },
		core.Result::Ok(id_str) => {
			match rest.validate_int("id", id_str) {
				core.Result::Err(_) => { return 302; },
				core.Result::Ok(id_val) => {
					if id_val != 42 { return 303; }
				}
			}
		}
	}

	// Query int or default: query_param → validate_int, fallback to 1.
	val page_key = "page";
	var page = 1;
	match rest.query_param(&req, &page_key) {
		Optional::None => {},
		Optional::Some(page_str) => {
			match rest.validate_int("page", page_str) {
				core.Result::Err(_) => { return 304; },
				core.Result::Ok(v) => {
					page = v;
				}
			}
		}
	}
	if page != 2 { return 305; }

	return 0;
}

// --- Story 4: Query string extraction + shared int validation failure ---
// Acceptance test: uses validate_int() → verifies field entry contract + envelope.

fn scenario_query_int_parse_failure() nothrow -> Int {
	var req = rest.new_request("GET", "/v1/users/7");
	rest.add_path_param(&mut req, "id", "7");
	rest.add_query_param(&mut req, "page", "abc");

	// Attempt to parse page as int — should fail via validate_int.
	val page_key = "page";
	match rest.query_param(&req, &page_key) {
		Optional::None => { return 401; },
		Optional::Some(page_str) => {
			match rest.validate_int("page", page_str) {
				core.Result::Ok(_) => { return 402; },
				core.Result::Err(e) => {
					// Verify field entry contract from validator.
					if e.tag != "invalid-integer" { return 409; }
					if e.fields_json != "{\"page\":\"invalid-integer\"}" { return 410; }

					// Build envelope from the returned error directly.
					val event_id = "evt-ux2-s4";
					val resp = rest.error_envelope(&e, &event_id);
					if resp.status != 400 { return 403; }
					match json.parse(&resp.body) {
						core.Result::Err(_) => { return 404; },
						core.Result::Ok(env) => {
							val tag_key = "tag";
							match env.get(&tag_key) {
								Optional::None => { return 413; },
								Optional::Some(tg) => {
									match tg.as_string() {
										Optional::None => { return 414; },
										Optional::Some(tv) => {
											if tv != "invalid-integer" { return 415; }
										}
									}
								}
							}
							val fields_key = "fields";
							match env.get(&fields_key) {
								Optional::None => { return 405; },
								Optional::Some(fields) => {
									val pk = "page";
									match fields.get(&pk) {
										Optional::None => { return 406; },
										Optional::Some(pv) => {
											match pv.as_string() {
												Optional::None => { return 407; },
												Optional::Some(v) => {
													if v != "invalid-integer" { return 408; }
													return 0;
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

// --- Story 5: Mixed validation accumulation (3 fields) ---
// Acceptance test: uses validation collector with real extractor/validator errors.

fn scenario_three_field_accumulation() nothrow -> Int {
	var req = rest.new_request("POST", "/v1/users");
	req.body = "{\"name\":\"ab\",\"age\":\"not-a-number\"}";

	match rest.body_json(&req) {
		core.Result::Err(_) => { return 501; },
		core.Result::Ok(handle) => {
			val node = handle.node();
			var ve = rest.new_validation_errors();

			// email — missing field.
			match rest.require_json_string(node, "email") {
				core.Result::Ok(_) => { return 502; },
				core.Result::Err(e) => {
					rest.merge_validation_error(&mut ve, move e);
				}
			}

			// age — wrong type (string, not int).
			match rest.require_json_int(node, "age") {
				core.Result::Ok(_) => { return 503; },
				core.Result::Err(e) => {
					rest.merge_validation_error(&mut ve, move e);
				}
			}

			// name — present but too short (min 3).
			match rest.require_json_string(node, "name") {
				core.Result::Err(_) => { return 504; },
				core.Result::Ok(name_val) => {
					match rest.validate_min_length("name", name_val, 3) {
						core.Result::Ok(_) => { return 505; },
						core.Result::Err(e) => {
							rest.merge_validation_error(&mut ve, move e);
						}
					}
				}
			}

			if rest.has_validation_errors(&ve) != true { return 506; }

			val err = rest.validation_error(move ve);
			if err.status != 400 { return 507; }
			if err.event != "request-invalid" { return 508; }
			if err.tag != "validation-failed" { return 509; }

			val event_id = "evt-ux2-s5";
			val resp = rest.error_envelope(&err, &event_id);
			if resp.status != 400 { return 510; }
			match json.parse(&resp.body) {
				core.Result::Err(_) => { return 511; },
				core.Result::Ok(env) => {
					val fields_key = "fields";
					match env.get(&fields_key) {
						Optional::None => { return 512; },
						Optional::Some(fields) => {
							// Verify email=missing-field.
							val ek = "email";
							match fields.get(&ek) {
								Optional::None => { return 513; },
								Optional::Some(ev) => {
									match ev.as_string() {
										Optional::None => { return 514; },
										Optional::Some(v) => {
											if v != "missing-field" { return 515; }
										}
									}
								}
							}
							// Verify age=invalid-type.
							val ak = "age";
							match fields.get(&ak) {
								Optional::None => { return 516; },
								Optional::Some(av) => {
									match av.as_string() {
										Optional::None => { return 517; },
										Optional::Some(v) => {
											if v != "invalid-type" { return 518; }
										}
									}
								}
							}
							// Verify name=too-short.
							val nk = "name";
							match fields.get(&nk) {
								Optional::None => { return 519; },
								Optional::Some(nv) => {
									match nv.as_string() {
										Optional::None => { return 520; },
										Optional::Some(v) => {
											if v != "too-short" { return 521; }
											return 0;
										}
									}
								}
							}
						}
					}
				}
			}
		}
	}
}

// --- Story 6: Body parse caching — acceptance test ---
// Verifies that dispatch-path caching parses once; subsequent body_json() returns cached handle.
// Mutating req.body after caching proves second call returns the cached (alice) result, not a re-parse.
// Uses internal request.cache_body_json (not on public facade — dispatch calls it automatically).

fn scenario_body_parse_caching() nothrow -> Int {
	var req = rest.new_request("POST", "/v1/users");
	req.body = "{\"name\":\"alice\"}";

	// Populate cache (simulates what dispatch does internally).
	request.cache_body_json(&mut req);

	// First body_json — should return cached handle with name=alice.
	match rest.body_json(&req) {
		core.Result::Err(_) => { return 601; },
		core.Result::Ok(handle1) => {
			val n1 = handle1.node();
			val k1 = "name";
			match n1.get(&k1) {
				Optional::None => { return 602; },
				Optional::Some(v1_node) => {
					match v1_node.as_string() {
						Optional::None => { return 603; },
						Optional::Some(v1) => {
							if v1 != "alice" { return 604; }
						}
					}
				}
			}
		}
	}

	// Mutate the body — if caching works, body_json() still returns alice.
	req.body = "{\"name\":\"bob\"}";

	// Second body_json — must still return cached alice, NOT bob.
	match rest.body_json(&req) {
		core.Result::Err(_) => { return 605; },
		core.Result::Ok(handle2) => {
			val n2 = handle2.node();
			val k2 = "name";
			match n2.get(&k2) {
				Optional::None => { return 606; },
				Optional::Some(v2_node) => {
					match v2_node.as_string() {
						Optional::None => { return 607; },
						Optional::Some(v2) => {
							if v2 != "alice" { return 608; }
						}
					}
				}
			}
		}
	}

	return 0;
}

// --- Story 7: Optional query param with default ---
// Acceptance test: uses validate_int() for present/invalid cases.

fn scenario_optional_query_default() nothrow -> Int {
	// Missing case: query_param → None → default.
	var req_missing = rest.new_request("GET", "/v1/users/42");
	rest.add_path_param(&mut req_missing, "id", "42");

	val page_key = "page";
	var page1 = 1;
	match rest.query_param(&req_missing, &page_key) {
		Optional::None => {},
		Optional::Some(page_str) => {
			match rest.validate_int("page", page_str) {
				core.Result::Err(_) => { return 701; },
				core.Result::Ok(v) => { page1 = v; }
			}
		}
	}
	if page1 != 1 { return 702; }

	// Valid case: query_param → Some → validate_int → Ok(2).
	var req_present = rest.new_request("GET", "/v1/users/42");
	rest.add_path_param(&mut req_present, "id", "42");
	rest.add_query_param(&mut req_present, "page", "2");

	var page2 = 1;
	match rest.query_param(&req_present, &page_key) {
		Optional::None => {},
		Optional::Some(page_str) => {
			match rest.validate_int("page", page_str) {
				core.Result::Err(_) => { return 703; },
				core.Result::Ok(v) => { page2 = v; }
			}
		}
	}
	if page2 != 2 { return 704; }

	// Invalid case: query_param → Some → validate_int → Err.
	var req_bad = rest.new_request("GET", "/v1/users/42");
	rest.add_path_param(&mut req_bad, "id", "42");
	rest.add_query_param(&mut req_bad, "page", "abc");

	match rest.query_param(&req_bad, &page_key) {
		Optional::None => { return 705; },
		Optional::Some(page_str) => {
			match rest.validate_int("page", page_str) {
				core.Result::Ok(_) => { return 706; },
				core.Result::Err(e) => {
					if e.tag != "invalid-integer" { return 707; }
					return 0;
				}
			}
		}
	}
}

fn main() nothrow -> Int {
	val a = scenario_malformed_json_body();
	if a != 0 { return a; }
	val b = scenario_validation_fields_email_age();
	if b != 0 { return b; }
	val c = scenario_path_int_query_default();
	if c != 0 { return c; }
	val d = scenario_query_int_parse_failure();
	if d != 0 { return d; }
	val e = scenario_three_field_accumulation();
	if e != 0 { return e; }
	val f = scenario_body_parse_caching();
	if f != 0 { return f; }
	val g = scenario_optional_query_default();
	if g != 0 { return g; }
	return 0;
}
