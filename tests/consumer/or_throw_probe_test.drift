module consumer.or_throw_probe_test;

import std.core as core;
import std.console as console;
import probe as probe;

// K28 diagnostic probe. Consumes the or-throw-probe package via --dep and
// exercises .or_throw() on Result<T, E> across the package boundary, where
// E is a `pub error` carrier (ABI 14 contract).
//
// The earlier `make_string_err()` scenario probing `Result<Int, String>`
// via or_throw is retired: under ABI 14 the Err type of `or_throw()` MUST
// be a `pub error` (E_OR_THROW_NOT_ERROR_TYPE), so the path no longer
// compiles. `make_string_err()` itself stays exported; only the consumer
// scenario that called .or_throw() on it is removed.

// Scenario 1: make_probe_ok().or_throw() returns 42.
fn scenario_probe_ok() nothrow -> Int {
	try {
		val v = probe.make_probe_ok().or_throw();
		if v == 42 { return 0; }
		return 1;
	} catch probe:ProbeError(_) {
		return 2;
	} catch {
		return 3;
	}
	return 99;
}

// Scenario 2: make_probe_err().or_throw() throws probe:ProbeError.
fn scenario_probe_err() nothrow -> Int {
	try {
		val _ = probe.make_probe_err().or_throw();
		return 1;
	} catch probe:ProbeError(_) {
		return 0;
	} catch {
		return 2;
	}
	return 99;
}

fn main() nothrow -> Int {
	val a = scenario_probe_ok();
	if a != 0 { return 100 + a; }
	val b = scenario_probe_err();
	if b != 0 { return 200 + b; }
	console.println("consumer or-throw-probe: all 2 scenarios passed");
	return 0;
}
