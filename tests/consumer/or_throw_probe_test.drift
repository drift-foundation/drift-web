module consumer.or_throw_probe_test;

import std.core as core;
import std.err as stderr;
import std.console as console;
import probe as probe;

// K28 diagnostic probe. Consumes the or-throw-probe package via --dep and
// exercises .or_throw() on Result<T, E> values returned across the package
// boundary, for two E shapes:
//   - package-local producer error (ProbeError → probe:ProbeException)
//   - stdlib E (String → std.err:ResultError via stdlib Throw impl)

// Scenario 1: make_probe_ok().or_throw() returns 42.
fn scenario_probe_ok() nothrow -> Int {
	try {
		val v = probe.make_probe_ok().or_throw();
		if v == 42 { return 0; }
		return 1;
	} catch probe:ProbeException(_) {
		return 2;
	} catch {
		return 3;
	}
	return 99;
}

// Scenario 2: make_probe_err().or_throw() throws probe:ProbeException.
fn scenario_probe_err() nothrow -> Int {
	try {
		val _ = probe.make_probe_err().or_throw();
		return 1;
	} catch probe:ProbeException(_) {
		return 0;
	} catch {
		return 2;
	}
	return 99;
}

// Scenario 3: make_string_err().or_throw() throws std.err:ResultError.
fn scenario_string_err() nothrow -> Int {
	try {
		val _ = probe.make_string_err().or_throw();
		return 1;
	} catch stderr:ResultError(_) {
		return 0;
	} catch {
		return 2;
	}
	return 99;
}

fn main() nothrow -> Int {
	val a = scenario_probe_ok();
	if a != 0 { return 100 + a; }
	val b = scenario_probe_err();
	if b != 0 { return 200 + b; }
	val c = scenario_string_err();
	if c != 0 { return 300 + c; }
	console.println("consumer or-throw-probe: all 3 scenarios passed");
	return 0;
}
