module consumer.rest_sequential_test;

import std.core as core;
import std.io as io;
import std.net as net;
import std.concurrent as conc;
import std.console as console;
import std.format as fmt;
import web.rest as rest;

// Consumer-path regression: sequential request handling across connections.
//
// Defect class (0.27.125): web-rest server returns read-failed on the second
// connection when multiple separate TCP connections are made in sequence.
// First connection works, second fails. The bug reproduces on both source-built
// and consumer-built paths.
//
// Scenarios:
//   1. Two requests on one keep-alive connection (both must succeed)
//   2. Two requests on SEPARATE connections (both must succeed)
//   3. Request with explicit Connection: close (must succeed)

fn health(req: &rest.Request, c: &mut rest.Context) nothrow -> core.Result<rest.Response, rest.RestError> {
	return core.Result::Ok(rest.json_response(200, "{\"ok\":true}"));
}

fn _send_one(addr: &net.SocketAddr, raw_req: &String, timeout: conc.Duration) nothrow -> core.Result<String, String> {
	match net.connect(addr, timeout) {
		core.Result::Err(_) => { return core.Result::Err("connect failed"); },
		core.Result::Ok(conn) => {
			var stream = move conn;
			val bytes = raw_req.byte_length();
			var wbuf = io.buffer(bytes);
			var i = 0;
			while i < bytes {
				io.buffer_write(&mut wbuf, i, core.string_byte_at(raw_req, i));
				i = i + 1;
			}
			match stream.write(&wbuf, timeout) {
				core.Result::Err(_) => {
					val _ = stream.close(timeout);
					return core.Result::Err("write failed");
				},
				core.Result::Ok(_) => {}
			}
			var resp: Array<Byte> = [];
			var done = false;
			while !done {
				var rbuf = io.buffer(4096);
				match stream.read(&mut rbuf, timeout) {
					core.Result::Err(_) => { done = true; },
					core.Result::Ok(n) => {
						if n == 0 { done = true; }
						else {
							var j = 0;
							while j < n {
								resp.push(io.buffer_read(&mut rbuf, j));
								j = j + 1;
							}
						}
					}
				}
			}
			val _ = stream.close(timeout);
			val rlen = resp.len;
			if rlen == 0 { return core.Result::Err("empty response"); }
			var sb = io.buffer(rlen);
			i = 0;
			while i < rlen {
				io.buffer_write(&mut sb, i, resp[i]);
				i = i + 1;
			}
			return core.Result::Ok(core.string_from_utf8_bytes(io.buffer_ptr(&sb), rlen));
		}
	}
}

fn _send_on_stream(stream: &mut net.TcpStream, raw_req: &String, timeout: conc.Duration) nothrow -> core.Result<String, String> {
	val bytes = raw_req.byte_length();
	var wbuf = io.buffer(bytes);
	var i = 0;
	while i < bytes {
		io.buffer_write(&mut wbuf, i, core.string_byte_at(raw_req, i));
		i = i + 1;
	}
	match stream.write(&wbuf, timeout) {
		core.Result::Err(_) => { return core.Result::Err("write failed"); },
		core.Result::Ok(_) => {}
	}
	var resp: Array<Byte> = [];
	var done = false;
	while !done {
		var rbuf = io.buffer(4096);
		match stream.read(&mut rbuf, timeout) {
			core.Result::Err(_) => { done = true; },
			core.Result::Ok(n) => {
				if n == 0 { done = true; }
				else {
					var j = 0;
					while j < n {
						resp.push(io.buffer_read(&mut rbuf, j));
						j = j + 1;
					}
					if resp.len > 50 { done = true; }
				}
			}
		}
	}
	val rlen = resp.len;
	if rlen == 0 { return core.Result::Err("empty response"); }
	var sb = io.buffer(rlen);
	i = 0;
	while i < rlen {
		io.buffer_write(&mut sb, i, resp[i]);
		i = i + 1;
	}
	return core.Result::Ok(core.string_from_utf8_bytes(io.buffer_ptr(&sb), rlen));
}

fn _contains(haystack: &String, needle: &String) nothrow -> Bool {
	val h_len = haystack.byte_length();
	val n_len = needle.byte_length();
	if n_len > h_len { return false; }
	var i = 0;
	val limit = h_len - n_len + 1;
	while i < limit {
		var matched = true;
		var j = 0;
		while j < n_len {
			if core.string_byte_at(haystack, i + j) != core.string_byte_at(needle, j) {
				matched = false;
				j = n_len;
			} else {
				j = j + 1;
			}
		}
		if matched { return true; }
		i = i + 1;
	}
	return false;
}

fn _assert_200(resp: &String, label: &String) nothrow -> Int {
	val ok_marker = "200 OK";
	val body_marker = "{\"ok\":true}";
	if !_contains(resp, &ok_marker) {
		console.println("FAIL " + *label + ": expected 200 OK, got: " + *resp);
		return 1;
	}
	if !_contains(resp, &body_marker) {
		console.println("FAIL " + *label + ": missing body");
		return 2;
	}
	return 0;
}

fn main() nothrow -> Int {
	// Client I/O uses a real timeout; server starts with millis=0 to cover
	// the exact trigger from the 0.27.125 defect report.
	val client_timeout = conc.Duration(millis = 5000);

	var b = rest.new_app_builder();
	rest.bind(&mut b, "127.0.0.1", 0);
	match rest.build_app(move b) {
		core.Result::Err(_) => { return 1; },
		core.Result::Ok(a) => {
			var app = move a;
			match rest.add_route(&mut app, "GET", "/health", core.callback2(health)) {
				core.Result::Err(_) => { return 2; },
				core.Result::Ok(_) => {}
			}
			match rest.start(move app, conc.Duration(millis = 0)) {
				core.Result::Err(e) => {
					console.println("FAIL: start: " + e.message);
					return 3;
				},
				core.Result::Ok(rs) => {
					var running = move rs;
					val port = rest.server_port(&running);
					var addr = net.socket_addr("127.0.0.1", port);

					// --- Scenario 1: two requests on one keep-alive connection ---
					match net.connect(&addr, client_timeout) {
						core.Result::Err(_) => {
							console.println("FAIL: scenario 1 connect");
							val _ = rest.shutdown(&mut running);
							return 10;
						},
						core.Result::Ok(conn) => {
							var stream = move conn;
							val req_ka = "GET /health HTTP/1.1\r\nHost: localhost\r\n\r\n";
							match _send_on_stream(&mut stream, &req_ka, client_timeout) {
								core.Result::Err(e) => {
									console.println("FAIL: scenario 1 req 1: " + e);
									val _ = stream.close(client_timeout);
									val _ = rest.shutdown(&mut running);
									return 11;
								},
								core.Result::Ok(r1) => {
									val l1 = "scenario 1 req 1";
									if _assert_200(&r1, &l1) != 0 {
										val _ = stream.close(client_timeout);
										val _ = rest.shutdown(&mut running);
										return 12;
									}
								}
							}
							match _send_on_stream(&mut stream, &req_ka, client_timeout) {
								core.Result::Err(e) => {
									console.println("FAIL: scenario 1 req 2: " + e);
									val _ = stream.close(client_timeout);
									val _ = rest.shutdown(&mut running);
									return 13;
								},
								core.Result::Ok(r2) => {
									val l2 = "scenario 1 req 2";
									if _assert_200(&r2, &l2) != 0 {
										val _ = stream.close(client_timeout);
										val _ = rest.shutdown(&mut running);
										return 14;
									}
								}
							}
							val _ = stream.close(client_timeout);
						}
					}

					// --- Scenario 2: 5 requests on SEPARATE connections ---
					// Matches the curl-style pattern from the app-team repro.
					val req_close = "GET /health HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n";
					var sep_i = 0;
					while sep_i < 5 {
						match _send_one(&addr, &req_close, client_timeout) {
							core.Result::Err(e) => {
								console.println("FAIL: scenario 2 req " + fmt.format_int(sep_i + 1) + ": " + e);
								val _ = rest.shutdown(&mut running);
								return 20 + sep_i;
							},
							core.Result::Ok(r) => {
								val l = "scenario 2 req " + fmt.format_int(sep_i + 1) + " (separate conn)";
								if _assert_200(&r, &l) != 0 {
									val _ = rest.shutdown(&mut running);
									return 20 + sep_i;
								}
							}
						}
						sep_i = sep_i + 1;
					}

					// --- Scenario 3: explicit Connection: close ---
					match _send_one(&addr, &req_close, client_timeout) {
						core.Result::Err(e) => {
							console.println("FAIL: scenario 3 (conn close): " + e);
							val _ = rest.shutdown(&mut running);
							return 30;
						},
						core.Result::Ok(r) => {
							val l = "scenario 3 (conn close)";
							if _assert_200(&r, &l) != 0 {
								val _ = rest.shutdown(&mut running);
								return 31;
							}
						}
					}

					match rest.shutdown(&mut running) {
						core.Result::Err(_) => { return 40; },
						core.Result::Ok(_) => {
							console.println("consumer rest-sequential: all 3 scenarios passed");
							return 0;
						}
					}
				}
			}
		}
	}
}
